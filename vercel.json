{
  "functions": {
    "api/index.py": {
      "includeFiles": "{config/**,data/reporting_knowledge_seed.json,src/**}",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/web/index.html"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/slack/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/data/:path*",
      "destination": "/api/index.py"
    }
  ]
}
