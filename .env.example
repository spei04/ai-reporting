OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=auto
OPENAI_MODEL_CANDIDATES=gpt-5.4-mini,gpt-5.4,gpt-5.5,gpt-4o-mini,gpt-4o

# Deployment/runtime
# Leave blank locally. Vercel automatically uses /tmp/ai_reporting when VERCEL=true.
AI_REPORTING_RUNTIME_DIR=
AI_REPORTING_PUBLIC_BASE_URL=https://your-public-domain.example.com

# Slack integration
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your-development-bot-token
SLACK_REDIRECT_URI=https://your-public-domain.example.com/api/slack/oauth/callback
SLACK_SCOPES=commands,chat:write,app_mentions:read,im:history,im:read,im:write,files:read
SLACK_ALLOWED_TEAM_IDS=
SLACK_ALLOW_UNSIGNED_DEV=false
